{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@controllers/*": [
                "src/controllers/*"
            ],
            "@routes/*": [
                "src/routes/*"
            ],
            "@middlewares/*": [
                "src/middlewares/*"
            ],
            "@utils/*": [
                "src/utils/*"
            ],
            "@validators/*": [
                "src/validators/*"
            ],
            "@config/*": [
                "src/config/*"
            ],
            "@appTypes/*": [
                "src/types/*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "logs",
        "prisma.config.ts",
        "prisma/**/*"
    ]
}